{
  "name": "sqlfu-drizzle-benchmark",
  "version": "1.0.0",
  "description": "Local sqlfu comparison target for drizzle-team/drizzle-benchmarks",
  "private": true,
  "main": "index.js",
  "scripts": {
    "bench": "tsx bench/index.ts --host http://localhost:3000 --name my-bench --folder results",
    "bench:drizzle": "tsx bench/index.ts --host http://localhost:3000 --name drizzle --folder results",
    "bench:go": "tsx bench/index.ts --host http://localhost:3002 --name go --folder results",
    "bench:sqlfu": "tsx bench/index.ts --host http://localhost:3003 --name sqlfu --folder results",
    "bench:sqlfu:bun": "tsx bench/index.ts --host http://localhost:3004 --name sqlfu-bun --folder results",
    "start:docker": "tsx ./src/docker.ts",
    "start:seed": "tsx ./src/seed.ts",
    "start:seed:sqlite": "tsx ./src/sqlite/seed.ts",
    "start:generate": "tsx ./src/generate.ts",
    "prepare:prisma": "prisma generate --schema src/schema.prisma",
    "prepare:prisma:sqlite": "prisma generate --schema src/sqlite/schema.prisma",
    "start:prisma": "tsx ./src/prisma-server-node.ts",
    "start:drizzle": "tsx ./src/drizzle-server-node.ts",
    "start:drizzle:node": "tsx ./src/drizzle-server-node.ts",
    "start:drizzle:bun": "bun ./src/drizzle-server-bun.ts",
    "start:go": "go run ./go",
    "start:sqlfu": "tsx ./src/sqlfu-server-node.ts",
    "start:sqlfu:bun": "bun ./src/sqlfu-server-bun.ts",
    "typecheck": "tsc -p tsconfig.sqlfu.json --noEmit",
    "typecheck:postgres": "tsc --noEmit --skipLibCheck --esModuleInterop --strict --module commonjs --target es2022 --moduleResolution node src/docker.ts src/drizzle-server-node.ts src/drizzle-server-bun.ts src/seed.ts src/generate.ts src/schema.ts src/relations.ts src/cpu-usage.ts",
    "typecheck:upstream": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@balena/dockerignore": "^1.0.2",
    "@faker-js/faker": "^8.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bun": "^1.1.6",
    "@types/deep-diff": "^1.0.2",
    "@types/dockerode": "^3.3.19",
    "@types/k6": "^0.45.2",
    "@types/pg": "^8.10.2",
    "@types/pidusage": "^2.0.2",
    "@types/ramda": "^0.29.3",
    "deep-diff": "^1.0.2",
    "dockerode": "^3.3.5",
    "drizzle-kit": "1.0.0-rc.1",
    "esbuild": "^0.19.2",
    "get-port": "^7.0.0",
    "k6": "^0.0.0",
    "postgres": "^3.3.5",
    "tsx": "^3.12.7",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@duckdb/node-api": "1.4.2-r.1",
    "@hono/node-server": "^1.19.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "axios": "^1.4.0",
    "better-sqlite3": "^12.5.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "drizzle-orm": "1.0.0-rc.1",
    "duckdb": "^1.0.0",
    "elysia": "^1.4.28",
    "hono": "^4.12.15",
    "pg": "^8.20.0",
    "pidusage": "^3.0.2",
    "prisma": "^7.8.0",
    "ramda": "^0.29.0",
    "sqlfu": "file:../../packages/sqlfu"
  }
}
