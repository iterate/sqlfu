---
import '../styles/landing.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>sqlfu</title>
    <meta
      name="description"
      content="sqlfu keeps schema, migrations, and queries in SQL files, then generates typed TypeScript wrappers, migration drafts, and named runtime calls."
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {/* Mirror Starlight's theme bootstrap: read localStorage 'starlight-theme' key
        and apply data-theme to <html> before first paint to avoid FOUC. Also picks
        up OS preference when no explicit choice is stored. */}
    <script is:inline>
      (() => {
        const stored =
          typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
        const theme =
          stored ||
          (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme === 'light' ? 'light' : 'dark';
      })();
    </script>
  </head>
  <body>
    <div class="prealpha-notice">
      <strong>pre-alpha.</strong> The TypeScript API may still shift. The SQL won't.
    </div>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo.png" alt="" width="28" height="28" />
          <span>sqlfu</span>
        </a>
        <nav class="nav">
          <a href="/docs/getting-started">Docs</a>
          <a href="/ui?demo=1">Demo</a>
          <a href="https://github.com/mmkal/sqlfu" target="_blank" rel="noreferrer">GitHub</a>
          <button
            type="button"
            class="theme-toggle"
            id="landing-theme-toggle"
            aria-label="Toggle colour theme"
            title="Toggle colour theme"
          >
            <span class="toggle-glyph" aria-hidden="true"></span>
          </button>
        </nav>
      </header>

      <section class="hero hero-solo">
        <article class="hero-main">
          <div class="eyebrow lowercase">npm install sqlfu</div>
          <h1>all you need is sql.</h1>
          <p class="lede">
            Put the data layer in files your team can review: <code>definitions.sql</code> for the schema, <code>migrations/*.sql</code> for history, and <code>sql/*.sql</code> for queries. sqlfu turns those files into typed wrappers, migration drafts, and named runtime calls.
          </p>
          <div class="cta-row">
            <a class="button primary" href="/docs/getting-started">Start tutorial</a>
            <a class="button" href="/ui?demo=1">Try in browser</a>
          </div>
        </article>
      </section>

      <figure class="showreel">
        <img src="/docs/assets/packages/sqlfu/docs/i-know-sqlfu.webp" alt="I know sqlfu" />
      </figure>

      <h2 class="section-title">The path through a sqlfu project</h2>
      <section class="feature-stack" id="value-panels">
        <article class="feature-row value-panel" data-animation-key="draft" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">1. schema + migration</div>
            <h3>Change the schema; draft the SQL.</h3>
            <p>
              Edit <code>definitions.sql</code> to the shape you want. <code>sqlfu draft</code> compares that desired schema with replayed migration history, shows the smart diff, then writes the reviewed migration file.
            </p>
            <a href="/docs/migration-model">Read the migration model</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Schema edit and draft command">
            <figure class="artifact artifact-tall">
              <figcaption>definitions.sql</figcaption>
              <pre><code><span class="tok-keyword">create table</span> <span class="tok-name">posts</span> (
  <span class="tok-name">id</span> <span class="tok-keyword">integer primary key autoincrement</span>,
  <span class="tok-name">slug</span> <span class="tok-keyword">text not null unique</span>,
  <span class="tok-name">title</span> <span class="tok-keyword">text not null</span>
<span class="diff-line diff-added" data-type-speed="schema-add" data-reveal-line data-reveal-pause="620" data-hide-typing-whitespace>+ <span class="tok-name">published</span> <span class="tok-keyword">integer</span></span>);</code></pre>
            </figure>
            <figure class="artifact terminal artifact-tall">
              <figcaption class="artifact-caption-actions">
                <span>terminal</span>
                <button class="demo-replay" type="button" data-replay-demo aria-label="Replay schema and migration animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </figcaption>
              <pre><code><span data-type-speed="command" data-run-command="true"><span class="term-prompt">$</span> <span class="tok-command">npx sqlfu draft</span></span>
<span class="terminal-output terminal-block" data-terminal-output data-output-pause="1450">│
◇  Create migration file? ─────────────────╮
│                                          │
│  alter table posts add column           │
│    published integer;                   │
│                                          │
<span data-corner-before-next>├──────────────────────────────────────────╯
</span><span data-corner-after-next>╰──────────────────────────────────────────╯
</span><span data-dismiss-before-next>│
◆  Continue with this body?
│  ● Yes
│  ○ No
│  ○ Edit with code
│  ○ Edit with vi
│  ○ Edit with nano</span>
<span class="terminal-output terminal-block" data-terminal-output data-output-pause="0">Wrote migrations/20260501090000_add_published_to_posts.sql</span></code></pre>
            </figure>
          </div>
        </article>

        <article class="feature-row value-panel" data-animation-key="generate" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">2. type generation</div>
            <h3>Generate functions from checked-in queries.</h3>
            <p>
              Query files are the source. <code>sqlfu generate</code> reads the live schema and emits TypeScript wrappers with typed params, typed result rows, and the query name attached for runtime use.
            </p>
            <a href="/docs/typegen">See query shapes</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Query file and generated TypeScript">
            <figure class="artifact artifact-tall">
              <figcaption>sql/get-posts.sql</figcaption>
              <pre><code data-type-speed="fast"><span class="tok-keyword">select</span> <span class="tok-name">id</span>, <span class="tok-name">slug</span>, <span class="tok-name">title</span>
<span class="tok-keyword">from</span> <span class="tok-name">posts</span>
<span class="tok-keyword">where</span> <span class="tok-name">published</span> = <span class="tok-number">1</span>
<span class="tok-keyword">order by</span> <span class="tok-name">id</span> <span class="tok-keyword">desc</span>
<span class="tok-keyword">limit</span> <span class="tok-param">:limit</span>;</code></pre>
            </figure>
            <div class="artifact artifact-tall artifact-tabs" data-tabbed-artifact>
              <div class="artifact-tablist" role="tablist" aria-label="Type generation output">
                <button class="artifact-tab is-active" type="button" role="tab" aria-selected="true" data-tab-for="terminal">terminal</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="src">src/posts.ts</button>
                <button class="demo-replay artifact-tab-replay" type="button" data-replay-demo aria-label="Replay type generation animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </div>
              <div class="artifact-tab-panel terminal is-active" role="tabpanel" data-terminal-artifact data-tab-panel="terminal">
                <pre><code><span data-type-speed="command" data-run-command="true"><span class="term-prompt">$</span> <span class="tok-command">npx sqlfu generate</span></span>
<span class="terminal-output terminal-block" data-terminal-output data-output-pause="820">Updated generated files:
  sql/.generated/get-posts.sql.ts
  sql/.generated/index.ts
  sql/.generated/queries.ts
  sql/.generated/tables.ts
  .sqlfu/query-catalog.json</span></code></pre>
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-replacement-artifact data-tab-panel="src">
                <pre><code data-type-speed="generated-file"><span class="tok-keyword">import</span> &#123;<span class="tok-name">getPosts</span>&#125; <span class="tok-keyword">from</span> <span class="tok-string">"./.generated/get-posts.sql.ts"</span>;

<span class="tok-keyword">const</span> <span class="tok-name">posts</span> = <span class="tok-keyword">await</span> <span class="tok-name">getPosts</span>(<span class="tok-name">client</span>, &#123;<span class="tok-prop">limit</span>: <span class="tok-number">10</span>&#125;);
<span class="tok-comment">//    ^? Array&lt;&#123;id: number; slug: string; title: string&#125;&gt;</span>

<span class="tok-name">posts</span>.<span class="tok-prop">forEach</span>((<span class="tok-name">post</span>) =&gt; &#123;
  <span class="tok-name">console</span>.<span class="tok-prop">log</span>(<span class="tok-name">post</span>.<span class="tok-prop">slug</span> + <span class="tok-string">": "</span> + <span class="tok-name">post</span>.<span class="tok-prop">title</span>);
&#125;);</code></pre>
              </div>
            </div>
          </div>
        </article>

        <article class="feature-row value-panel" data-animation-key="runtime" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">3. runtime</div>
            <h3>Keep the wrapper when the driver changes.</h3>
            <p>
              Bring the SQLite driver your runtime already uses. The adapter preserves sync or async behavior, and the same generated function can feed OpenTelemetry, Sentry, PostHog, or Datadog through <code>instrument()</code>.
            </p>
            <a href="/docs/adapters">Choose an adapter</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Runtime client and query metadata">
            <figure class="artifact artifact-tall">
              <figcaption>application code</figcaption>
              <pre><code data-type-speed="fast"><span class="tok-keyword">const</span> <span class="tok-name">client</span> = <span class="tok-name">instrument</span>(
  <span class="tok-name">createNodeSqliteClient</span>(<span class="tok-name">db</span>),
  <span class="tok-name">instrument</span>.<span class="tok-prop">otel</span>(&#123;<span class="tok-prop">tracer</span>&#125;),
);

<span class="tok-keyword">await</span> <span class="tok-name">getPosts</span>(<span class="tok-name">client</span>, &#123;<span class="tok-prop">limit</span>: <span class="tok-number">10</span>&#125;);</code></pre>
            </figure>
            <figure class="artifact artifact-tall">
              <figcaption class="artifact-caption-actions">
                <span>query context</span>
                <button class="demo-replay" type="button" data-replay-demo aria-label="Replay runtime animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </figcaption>
              <pre data-generated-artifact><code><span class="tok-prop">db.query.summary</span> = <span class="tok-string">"getPosts"</span>
<span class="tok-prop">db.query.text</span> = <span class="tok-string">"select id, slug, title ..."</span>
<span class="tok-prop">db.system.name</span> = <span class="tok-string">"sqlite"</span></code></pre>
            </figure>
          </div>
        </article>
      </section>

      <p class="works-with">
        Driver support today: <code>better-sqlite3</code>, <code>node:sqlite</code>, <code>bun:sqlite</code>, <code>@libsql/client</code>, <code>@tursodatabase/database</code> / <code>serverless</code> / <code>sync</code>, Cloudflare D1, Durable Objects, Expo SQLite, and <code>sqlite-wasm</code>. <a href="/docs/adapters">Full list</a>
      </p>

      <script is:inline>
        (() => {
          const params = new URLSearchParams(window.location.search);
          if (params.get('animation')) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

          const rows = Array.from(document.querySelectorAll('[data-walkthrough-step]'));
          if (rows.length === 0) return;

          const sleep = milliseconds =>
            new Promise(resolve => {
              window.setTimeout(resolve, milliseconds);
            });

          const prepareTyping = target => {
            if (target.dataset.typingPrepared === 'true') {
              return Array.from(target.querySelectorAll('.typed-char'));
            }

            const textNodes = [];
            const walker = document.createTreeWalker(target, NodeFilter.SHOW_TEXT);
            let node = walker.nextNode();
            while (node) {
              if (node.nodeValue) textNodes.push(node);
              node = walker.nextNode();
            }

            for (const textNode of textNodes) {
              const fragment = document.createDocumentFragment();
              for (const character of textNode.nodeValue) {
                const span = document.createElement('span');
                span.className = 'typed-char';
                span.textContent = character;
                if (!character.trim() && !target.hasAttribute('data-hide-typing-whitespace')) {
                  span.classList.add('is-visible');
                }
                fragment.append(span);
              }
              textNode.replaceWith(fragment);
            }

            target.dataset.typingPrepared = 'true';
            return Array.from(target.querySelectorAll('.typed-char'));
          };

          const resetRow = row => {
            for (const character of row.querySelectorAll('.typed-char')) {
              const target = character.closest('[data-type-speed]');
              const hideWhitespace = target?.hasAttribute('data-hide-typing-whitespace');
              character.classList.toggle(
                'is-visible',
                !hideWhitespace && !character.textContent?.trim(),
              );
            }
            for (const revealLine of row.querySelectorAll('[data-reveal-line]')) {
              revealLine.classList.remove('is-visible');
            }
            for (const output of row.querySelectorAll('[data-terminal-output]')) {
              output.classList.remove('is-visible', 'is-dismissed');
            }
            for (const promptPart of row.querySelectorAll('[data-dismiss-before-next], [data-corner-before-next], [data-corner-after-next]')) {
              promptPart.classList.remove('is-visible', 'is-dismissed');
            }
            for (const artifact of row.querySelectorAll('[data-generated-artifact], [data-replacement-artifact]')) {
              artifact.classList.remove('is-visible');
            }
            for (const terminal of row.querySelectorAll('.artifact.terminal')) {
              terminal.classList.remove('is-running', 'is-done', 'is-replaced');
            }
            for (const tabbed of row.querySelectorAll('[data-tabbed-artifact]')) {
              switchArtifactTab(tabbed, 'terminal');
              tabbed.classList.remove('is-running', 'is-done');
            }
          };

          const revealTyping = async (target, isCurrent) => {
            if (target.hasAttribute('data-reveal-line')) {
              target.classList.add('is-visible');
              await sleep(Number(target.dataset.revealPause || 0));
              if (!isCurrent()) return false;
            }
            const delayBySpeed = {
              command: 78,
              fast: 14,
              'generated-file': 5,
              'schema-add': 58,
            };
            const delay = delayBySpeed[target.dataset.typeSpeed] || 14;
            for (const character of prepareTyping(target)) {
              if (!isCurrent()) return false;
              if (character.classList.contains('is-visible')) continue;
              character.classList.add('is-visible');
              await sleep(delay);
            }
            return true;
          };

          const switchArtifactTab = (tabbed, activeTab) => {
            for (const tab of tabbed.querySelectorAll('[data-tab-for]')) {
              tab.classList.toggle('is-active', tab.dataset.tabFor === activeTab);
              tab.setAttribute('aria-selected', String(tab.dataset.tabFor === activeTab));
            }
            for (const panel of tabbed.querySelectorAll('[data-tab-panel]')) {
              panel.classList.toggle('is-active', panel.dataset.tabPanel === activeTab);
            }
          };

          const setReplayState = (row, state) => {
            row.dataset.walkthroughState = state;
            for (const button of row.querySelectorAll('[data-replay-demo]')) {
              button.dataset.replayState = state;
            }
          };

          const playRow = async row => {
            const runId = String(Number(row.dataset.walkthroughRun || '0') + 1);
            row.dataset.walkthroughRun = runId;
            const isCurrent = () => row.dataset.walkthroughRun === runId;
            resetRow(row);
            setReplayState(row, 'running');

            try {
              for (const target of row.querySelectorAll('[data-type-speed]')) {
                const completed = await revealTyping(target, isCurrent);
                if (!completed || !isCurrent()) return;

                if (target.dataset.runCommand === 'true') {
                  const terminal = target.closest('.artifact');
                  if (terminal) terminal.classList.add('is-running');
                  await sleep(650);
                  let previousOutput = null;
                  for (const output of terminal?.querySelectorAll('[data-terminal-output]') || []) {
                    if (!isCurrent()) return;
                    if (previousOutput) {
                      if (previousOutput.hasAttribute('data-dismiss-before-next')) {
                        previousOutput.classList.add('is-dismissed');
                      }
                      for (const promptPart of previousOutput.querySelectorAll('[data-dismiss-before-next], [data-corner-before-next]')) {
                        promptPart.classList.add('is-dismissed');
                      }
                      for (const promptPart of previousOutput.querySelectorAll('[data-corner-after-next]')) {
                        promptPart.classList.add('is-visible');
                      }
                    }
                    output.classList.add('is-visible');
                    previousOutput = output;
                    await sleep(Number(output.dataset.outputPause || 260));
                  }
                  if (terminal) {
                    terminal.classList.remove('is-running');
                    terminal.classList.add('is-done');
                  }
                  await sleep(170);

                  const replacement = terminal
                    ?.closest('.artifact-swap')
                    ?.querySelector('[data-replacement-artifact]');
                  const tabbedReplacement = terminal
                    ?.closest('[data-tabbed-artifact]')
                    ?.querySelector('[data-replacement-artifact]');
                  const tabbed = terminal?.closest('[data-tabbed-artifact]');
                  if (replacement) {
                    terminal.classList.add('is-replaced');
                    replacement.classList.add('is-visible');
                  }
                  if (tabbed && tabbedReplacement) {
                    switchArtifactTab(tabbed, 'src');
                    tabbedReplacement.classList.add('is-visible');
                  }
                }
              }

              for (const artifact of row.querySelectorAll('[data-generated-artifact]')) {
                if (!isCurrent()) return;
                artifact.classList.add('is-visible');
                await sleep(110);
              }
            } finally {
              if (isCurrent()) setReplayState(row, 'done');
            }
          };

          for (const row of rows) {
            for (const target of row.querySelectorAll('[data-type-speed]')) {
              prepareTyping(target);
            }
          }
          document.documentElement.classList.add('landing-anim-ready');
          for (const row of rows) {
            resetRow(row);
            setReplayState(row, 'idle');
            for (const replayButton of row.querySelectorAll('[data-replay-demo]')) {
              replayButton.addEventListener('click', () => void playRow(row));
            }
            for (const tabbed of row.querySelectorAll('[data-tabbed-artifact]')) {
              for (const tab of tabbed.querySelectorAll('[data-tab-for]')) {
                tab.addEventListener('click', () => {
                  switchArtifactTab(tabbed, tab.dataset.tabFor || 'terminal');
                });
              }
            }
          }

          if (!('IntersectionObserver' in window)) {
            for (const row of rows) void playRow(row);
            return;
          }

          const observer = new IntersectionObserver(
            entries => {
              for (const entry of entries) {
                const row = entry.target.closest('[data-walkthrough-step]');
                if (!row) continue;
                const fullyVisible = entry.isIntersecting && entry.intersectionRatio >= 0.98;
                if (!fullyVisible) {
                  row.dataset.walkthroughFullyVisible = 'false';
                  continue;
                }
                if (row.dataset.walkthroughFullyVisible === 'true') continue;
                row.dataset.walkthroughFullyVisible = 'true';
                void playRow(row);
              }
            },
            { rootMargin: '0px', threshold: [0, 0.98, 1] },
          );

          for (const row of rows) {
            observer.observe(row.querySelector('.feature-demo') || row);
          }
        })();
      </script>

      {/*
        Video animation variants are enabled with `?animation=<name>`:

          - `?animation=sequential`: a single large stage that plays the three
            beats (schema, generate, draft) in sequence, replacing the
            feature walkthrough. This is the main animated treatment.
          - `?animation=a|b|c|d`: the original three-panel alternatives,
            each supported feature keeps its copy but its body gets swapped for the
            matching `alt-<letter>-<key>` video.

        When no `animation` param is set, the page keeps the feature
        walkthrough above and progressively enhances it with lightweight DOM
        typing/reveal animation.
      */}
      <script is:inline>
        (() => {
          const params = new URLSearchParams(window.location.search);
          const raw = params.get('animation');
          if (!raw) return;
          const name = raw.trim().toLowerCase();
          const grid = document.getElementById('value-panels');
          if (!grid) return;

          if (name === 'sequential') {
            // Single large stage. Replace the three-card grid wholesale.
            const stage = document.createElement('section');
            stage.className = 'animation-stage';
            stage.innerHTML = `
              <video
                class="animation-stage-video"
                autoplay
                loop
                muted
                playsinline
                preload="metadata"
                poster="/assets/animations/anim-sequential.poster.jpg"
              >
                <source src="/assets/animations/anim-sequential.webm" type="video/webm" />
                <source src="/assets/animations/anim-sequential.mp4" type="video/mp4" />
              </video>
              <img
                class="animation-stage-fallback"
                src="/assets/animations/anim-sequential.poster.jpg"
                alt="sqlfu: edit schema, generate types, draft migrations."
                loading="lazy"
              />
            `;
            grid.replaceWith(stage);
            return;
          }

          if (['a', 'b', 'c', 'd'].includes(name)) {
            const animatedKeys = new Set(['schema', 'generate', 'draft']);
            // Alternative three-panel treatments: inject a `<video>` inside
            // each feature that already has a matching animation asset.
            for (const panel of grid.querySelectorAll('.value-panel')) {
              const key = panel.dataset.animationKey;
              if (!key || !animatedKeys.has(key)) continue;
              const slug = `alt-${name}-${key}`;
              const media = document.createElement('div');
              media.className = 'value-media';
              media.innerHTML = `
                <video
                  class="value-video"
                  autoplay
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  poster="/assets/animations/${slug}.poster.jpg"
                >
                  <source src="/assets/animations/${slug}.webm" type="video/webm" />
                  <source src="/assets/animations/${slug}.mp4" type="video/mp4" />
                </video>
                <img
                  class="value-video-fallback"
                  src="/assets/animations/${slug}.poster.jpg"
                  alt=""
                  loading="lazy"
                />
              `;
              const heading = panel.querySelector('.eyebrow');
              if (heading) heading.after(media);
              else panel.prepend(media);
            }
          }
        })();
      </script>

      <footer class="footer">
        Use with your db: <code>npx sqlfu</code>.
      </footer>
    </div>

    {/* Landing-page theme toggle. Uses the same 'starlight-theme' localStorage key
        Starlight owns, so docs and landing stay in sync. Cycles light → dark → auto. */}
    <script is:inline>
      (() => {
        const key = 'starlight-theme';
        const button = document.getElementById('landing-theme-toggle');
        if (!button) return;

        const prefersLight = () => window.matchMedia('(prefers-color-scheme: light)').matches;

        const applyTheme = mode => {
          const resolved = mode === 'auto' ? (prefersLight() ? 'light' : 'dark') : mode;
          document.documentElement.dataset.theme = resolved;
          button.dataset.themeMode = mode;
        };

        const readMode = () => {
          const stored = localStorage.getItem(key);
          return stored === 'light' || stored === 'dark' ? stored : 'auto';
        };

        const writeMode = mode => {
          if (mode === 'auto') localStorage.setItem(key, '');
          else localStorage.setItem(key, mode);
        };

        applyTheme(readMode());

        button.addEventListener('click', () => {
          const current = readMode();
          const next = current === 'light' ? 'dark' : current === 'dark' ? 'auto' : 'light';
          writeMode(next);
          applyTheme(next);
        });

        // Keep landing in sync if the OS flips while we're on 'auto'.
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
          if (readMode() === 'auto') applyTheme('auto');
        });
      })();
    </script>
  </body>
</html>
