---
import '../styles/landing.css';
import SocialMeta from '../components/SocialMeta.astro';
import { renderDemo } from '../landing-demos/render';

const title = 'sqlfu';
const description =
  'sqlfu keeps schema, migrations, and queries in SQL files, then generates typed TypeScript wrappers, migration drafts, and named runtime calls.';

const demo = {
  draft: {
    definitions: await renderDemo('draft', 'definitions'),
    terminal: await renderDemo('draft', 'terminal'),
  },
  generate: {
    query: await renderDemo('generate', 'query'),
    terminal: await renderDemo('generate', 'terminal'),
    app: await renderDemo('generate', 'app'),
  },
  runtime: {
    app: await renderDemo('runtime', 'app'),
    node: await renderDemo('runtime', 'node'),
    bun: await renderDemo('runtime', 'bun'),
    better: await renderDemo('runtime', 'better'),
    libsql: await renderDemo('runtime', 'libsql'),
    wasm: await renderDemo('runtime', 'wasm'),
    expo: await renderDemo('runtime', 'expo'),
    do: await renderDemo('runtime', 'do'),
  },
  batteries: {
    cli: await renderDemo('batteries', 'cli'),
    admin: await renderDemo('batteries', 'admin'),
    tracing: await renderDemo('batteries', 'tracing'),
    lint: await renderDemo('batteries', 'lint'),
    formatter: await renderDemo('batteries', 'formatter'),
    skill: await renderDemo('batteries', 'skill'),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <SocialMeta title={title} description={description} pathname="/" type="website" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {/* Mirror Starlight's theme bootstrap: read localStorage 'starlight-theme' key
        and apply data-theme to <html> before first paint to avoid FOUC. Also picks
        up OS preference when no explicit choice is stored. */}
    <script is:inline>
      (() => {
        const stored =
          typeof localStorage !== 'undefined' && localStorage.getItem('starlight-theme');
        const theme =
          stored ||
          (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme === 'light' ? 'light' : 'dark';
      })();
    </script>
  </head>
  <body>
    <div class="prealpha-notice">
      <strong>pre-alpha.</strong> The TypeScript API may still shift. The SQL won't.
    </div>
    <div class="site-shell">
      <header class="topbar">
        <a class="brand" href="/">
          <img class="brand-logo" src="/logo.png" alt="" width="28" height="28" />
          <span>sqlfu</span>
        </a>
        <nav class="nav">
          <a href="/docs/getting-started">Docs</a>
          <a href="/ui?demo=1">Demo</a>
          <a href="https://github.com/mmkal/sqlfu" target="_blank" rel="noreferrer">GitHub</a>
          <button
            type="button"
            class="theme-toggle"
            id="landing-theme-toggle"
            aria-label="Toggle colour theme"
            title="Toggle colour theme"
          >
            <span class="toggle-glyph" aria-hidden="true"></span>
          </button>
        </nav>
      </header>

      <section class="hero hero-solo">
        <article class="hero-main">
          <div class="eyebrow lowercase">npm install sqlfu</div>
          <h1>all you need is sql.</h1>
          <p class="lede">
            Put the data layer in files your team can review: <code>definitions.sql</code> for the schema, <code>migrations/*.sql</code> for history, and <code>sql/*.sql</code> for queries. sqlfu turns those files into typed wrappers, migration drafts, and named runtime calls.
          </p>
          <div class="cta-row">
            <a class="button primary" href="/docs/getting-started">Start tutorial</a>
            <a class="button" href="/ui?demo=1">Try in browser</a>
          </div>
        </article>
      </section>

      <figure class="showreel">
        <img src="/docs/assets/packages/sqlfu/docs/i-know-sqlfu.webp" alt="I know sqlfu" />
      </figure>

      <h2 class="section-title">what sqlfu provides</h2>
      <section class="feature-stack" id="value-panels">
        <article class="feature-row value-panel" data-animation-key="draft" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">1. schema + migration</div>
            <h3>Your schema as SQL</h3>
            <p>
              Edit <code>definitions.sql</code> to the shape you want. <code>sqlfu draft</code> compares that desired schema with replayed migration history, shows the smart diff, then writes the reviewed migration file.
            </p>
            <a href="/docs/migration-model">Read about the migration model</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Schema edit and draft command">
            <figure class="artifact artifact-tall">
              <figcaption>{demo.draft.definitions.caption}</figcaption>
              <Fragment set:html={demo.draft.definitions.html} />
            </figure>
            <figure class="artifact terminal artifact-tall">
              <figcaption class="artifact-caption-actions">
                <span>{demo.draft.terminal.caption}</span>
                <button class="demo-replay" type="button" data-replay-demo aria-label="Replay schema and migration animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </figcaption>
              <Fragment set:html={demo.draft.terminal.html} />
            </figure>
          </div>
        </article>

        <article class="feature-row value-panel" data-animation-key="generate" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">2. typescript generation</div>
            <h3>Your queries as SQL</h3>
            <p>
              Query files are the source. <code>sqlfu generate</code> determines their types based on <code>definitions.sql</code>, then emits TypeScript wrappers with typed params, typed result rows, and the query name attached for runtime use.
            </p>
            <a href="/docs/typegen">Read about type generation</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Query file and generated TypeScript">
            <figure class="artifact artifact-tall">
              <figcaption>{demo.generate.query.caption}</figcaption>
              <Fragment set:html={demo.generate.query.html} />
            </figure>
            <div class="artifact artifact-tall artifact-tabs" data-tabbed-artifact>
              <div class="artifact-tablist" role="tablist" aria-label="Type generation output">
                <button class="artifact-tab is-active" type="button" role="tab" aria-selected="true" data-tab-for="terminal">terminal</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="src">src/app.ts</button>
                <button class="demo-replay artifact-tab-replay" type="button" data-replay-demo aria-label="Replay type generation animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </div>
              <div class="artifact-tab-panel terminal is-active" role="tabpanel" data-terminal-artifact data-tab-panel="terminal">
                <Fragment set:html={demo.generate.terminal.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-replacement-artifact data-tab-panel="src">
                <Fragment set:html={demo.generate.app.html} />
              </div>
            </div>
          </div>
        </article>

        <article class="feature-row value-panel" data-animation-key="runtime" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">3. runtime</div>
            <h3>One client interface, many drivers.</h3>
            <p>
              Your app code takes the sqlfu <code>Client</code> interface. <code>sqlfu</code> ships with many (very thin!) adapters, with graceful fallback for features like prepared statements depending on client support, and proper handling of synchronous clients. Pick from Node, Bun, better-sqlite3, libsql, expo, browser via wasm, Durable Object storage, and more.
            </p>
            <a href="/docs/adapters">Choose an adapter</a>
          </div>
          <div class="artifact-pair feature-demo" aria-label="Runtime client adapters">
            <figure class="artifact artifact-tall">
              <figcaption>{demo.runtime.app.caption}</figcaption>
              <Fragment set:html={demo.runtime.app.html} />
            </figure>
            <div class="artifact artifact-tall artifact-tabs runtime-tabs" data-tabbed-artifact data-default-tab="node">
              <div class="artifact-tablist" role="tablist" aria-label="Runtime adapter examples">
                <button class="artifact-tab is-active" type="button" role="tab" aria-selected="true" data-tab-for="node">node:sqlite</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="bun">bun:sqlite</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="better">better-sqlite3</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="libsql">libsql</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="wasm">sqlite-wasm</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="expo">expo-sqlite</button>
                <button class="artifact-tab" type="button" role="tab" aria-selected="false" data-tab-for="do">durable object</button>
                <button class="demo-replay" type="button" data-replay-demo aria-label="Replay runtime animation" title="Replay animation">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 11a8 8 0 1 0-2.34 5.66" />
                    <path d="M20 4v7h-7" />
                  </svg>
                </button>
              </div>
              <div class="artifact-tab-panel is-active" role="tabpanel" data-tab-panel="node">
                <Fragment set:html={demo.runtime.node.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="bun">
                <Fragment set:html={demo.runtime.bun.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="better">
                <Fragment set:html={demo.runtime.better.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="libsql">
                <Fragment set:html={demo.runtime.libsql.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="wasm">
                <Fragment set:html={demo.runtime.wasm.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="expo">
                <Fragment set:html={demo.runtime.expo.html} />
              </div>
              <div class="artifact-tab-panel" role="tabpanel" data-tab-panel="do">
                <Fragment set:html={demo.runtime.do.html} />
              </div>
            </div>
          </div>
        </article>

        <article class="feature-row value-panel feature-showcase-row" data-animation-key="batteries" data-walkthrough-step>
          <div class="feature-copy">
            <div class="eyebrow">4. batteries</div>
            <h3>Built-in goodies (if you want them)</h3>
            <p>
              Mostly you just need to ask your agent to write normal SQL files. <code>sqlfu</code> has great DX for covering review, tracing, linting, agent handoff, and more.
            </p>
          </div>
          <div class="feature-showcase feature-demo" data-feature-showcase aria-label="sqlfu workflow features">
            <div class="feature-switcher" role="tablist" aria-label="Workflow features">
              <button class="feature-option is-active" type="button" role="tab" aria-selected="true" data-feature-for="cli">CLI</button>
              <button class="feature-option" type="button" role="tab" aria-selected="false" data-feature-for="admin">Admin UI</button>
              <button class="feature-option" type="button" role="tab" aria-selected="false" data-feature-for="lint">Lint plugin</button>
              <button class="feature-option" type="button" role="tab" aria-selected="false" data-feature-for="formatter">Formatter</button>
              <button class="feature-option" type="button" role="tab" aria-selected="false" data-feature-for="tracing">Built-in tracing</button>
              <button class="feature-option" type="button" role="tab" aria-selected="false" data-feature-for="skill">Agent skill</button>
            </div>
            <div class="feature-showcase-stage">
              <section class="feature-showcase-panel is-active" role="tabpanel" data-feature-panel="cli">
                <figure class="artifact terminal">
                  <figcaption>{demo.batteries.cli.caption}</figcaption>
                  <Fragment set:html={demo.batteries.cli.html} />
                </figure>
              </section>
              <section class="feature-showcase-panel" role="tabpanel" data-feature-panel="admin">
                <figure class="artifact terminal artifact-compact">
                  <figcaption>{demo.batteries.admin.caption}</figcaption>
                  <Fragment set:html={demo.batteries.admin.html} />
                </figure>
                <figure class="ui-shot">
                  <img src="/assets/landing/sqlfu-ui-crop.png" alt="sqlfu UI showing a customers table" loading="lazy" />
                </figure>
              </section>
              <section class="feature-showcase-panel" role="tabpanel" data-feature-panel="tracing">
                <div class="artifact-pair artifact-pair-uneven">
                  <figure class="artifact">
                    <figcaption>{demo.batteries.tracing.caption}</figcaption>
                    <Fragment set:html={demo.batteries.tracing.html} />
                  </figure>
                  <div class="trace-shot" aria-label="Example trace view">
                    <div class="trace-shot-header">
                      <span>GET /posts</span>
                      <strong>42 ms</strong>
                    </div>
                    <div class="trace-row trace-row-root">
                      <span class="trace-label">GET /posts</span>
                      <span class="trace-bar"></span>
                      <span class="trace-time">42 ms</span>
                    </div>
                    <div class="trace-row trace-row-child">
                      <span class="trace-label">getPosts</span>
                      <span class="trace-bar"></span>
                      <span class="trace-time">8 ms</span>
                    </div>
                    <div class="trace-row trace-row-child trace-row-short">
                      <span class="trace-label">sqlite all</span>
                      <span class="trace-bar"></span>
                      <span class="trace-time">5 ms</span>
                    </div>
                    <dl>
                      <div><dt>db.query.summary</dt><dd>getPosts</dd></div>
                      <div><dt>db.system.name</dt><dd>sqlite</dd></div>
                    </dl>
                  </div>
                </div>
              </section>
              <section class="feature-showcase-panel" role="tabpanel" data-feature-panel="lint">
                <figure class="artifact terminal">
                  <figcaption>{demo.batteries.lint.caption}</figcaption>
                  <Fragment set:html={demo.batteries.lint.html} />
                </figure>
              </section>
              <section class="feature-showcase-panel" role="tabpanel" data-feature-panel="formatter">
                <figure class="artifact terminal">
                  <figcaption>{demo.batteries.formatter.caption}</figcaption>
                  <Fragment set:html={demo.batteries.formatter.html} />
                </figure>
              </section>
              <section class="feature-showcase-panel" role="tabpanel" data-feature-panel="skill">
                <figure class="artifact terminal">
                  <figcaption>{demo.batteries.skill.caption}</figcaption>
                  <Fragment set:html={demo.batteries.skill.html} />
                </figure>
              </section>
            </div>
          </div>
        </article>
      </section>

      <section class="tweet-testimonial" aria-label="Testimonial">
        <a
          class="tweet-card"
          href="https://x.com/samgoodwin89/status/2050276655047032915?s=20"
          target="_blank"
          rel="noreferrer"
        >
          <img
            class="tweet-avatar"
            src="/assets/landing/samgoodwin89-avatar.png"
            alt="sam"
            width="48"
            height="48"
            loading="lazy"
          />
          <span class="tweet-body">
            <span class="tweet-meta">
              <strong>sam</strong>
              <span class="tweet-verified" aria-label="verified"></span>
              <span>@samgoodwin89</span>
              <span aria-hidden="true">&middot;</span>
              <time datetime="2026-05-01">May 1, 2026</time>
            </span>
            <span class="tweet-text">I do love raw dogging SQL</span>
          </span>
          <span class="tweet-source" aria-hidden="true">X</span>
        </a>
      </section>

      <script is:inline>
        (() => {
          const params = new URLSearchParams(window.location.search);
          if (params.get('animation')) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

          const rows = Array.from(document.querySelectorAll('[data-walkthrough-step]'));
          if (rows.length === 0) return;

          const sleep = milliseconds =>
            new Promise(resolve => {
              window.setTimeout(resolve, milliseconds);
            });

          const prepareTyping = target => {
            if (target.dataset.typingPrepared === 'true') {
              return Array.from(target.querySelectorAll('.typed-char'));
            }

            const textNodes = [];
            const walker = document.createTreeWalker(target, NodeFilter.SHOW_TEXT);
            let node = walker.nextNode();
            while (node) {
              const parent = node.parentElement;
              if (node.nodeValue && !parent?.closest('.term-prompt')) textNodes.push(node);
              node = walker.nextNode();
            }

            for (const textNode of textNodes) {
              const fragment = document.createDocumentFragment();
              for (const character of textNode.nodeValue) {
                const span = document.createElement('span');
                span.className = 'typed-char';
                span.textContent = character;
                if (!character.trim() && !target.hasAttribute('data-hide-typing-whitespace')) {
                  span.classList.add('is-visible');
                }
                fragment.append(span);
              }
              textNode.replaceWith(fragment);
            }

            target.dataset.typingPrepared = 'true';
            return Array.from(target.querySelectorAll('.typed-char'));
          };

          const isTypingTargetActive = target => {
            const featurePanel = target.closest('[data-feature-panel]');
            return !featurePanel || featurePanel.classList.contains('is-active');
          };

          const typingTargetsForRow = row => {
            return Array.from(row.querySelectorAll('[data-type-speed]')).filter(isTypingTargetActive);
          };

          const showInitialCommandPrompts = row => {
            const terminals = new Set();
            for (const target of typingTargetsForRow(row)) {
              if (target.dataset.runCommand !== 'true') continue;

              const terminal = target.closest('.artifact');
              if (!terminal || terminals.has(terminal)) continue;

              target.classList.add('is-prompt-visible');
              terminals.add(terminal);
            }
          };

          const resetRow = row => {
            for (const character of row.querySelectorAll('.typed-char')) {
              const target = character.closest('[data-type-speed]');
              const hideWhitespace = target?.hasAttribute('data-hide-typing-whitespace');
              character.classList.toggle(
                'is-visible',
                !hideWhitespace && !character.textContent?.trim(),
              );
            }
            for (const revealLine of row.querySelectorAll('[data-reveal-line]')) {
              revealLine.classList.remove('is-visible');
            }
            for (const pop of row.querySelectorAll('[data-pop-after-typing]')) {
              pop.classList.remove('is-visible');
            }
            for (const output of row.querySelectorAll('[data-terminal-output]')) {
              output.classList.remove('is-visible', 'is-dismissed');
            }
            for (const promptPart of row.querySelectorAll('[data-dismiss-before-next], [data-corner-before-next], [data-corner-after-next]')) {
              promptPart.classList.remove('is-visible', 'is-dismissed');
            }
            for (const artifact of row.querySelectorAll('[data-generated-artifact], [data-replacement-artifact]')) {
              artifact.classList.remove('is-visible');
            }
            for (const terminal of row.querySelectorAll('.artifact.terminal')) {
              terminal.classList.remove('is-running', 'is-done', 'is-replaced');
            }
            for (const commandLine of row.querySelectorAll('.terminal-command-line')) {
              commandLine.classList.remove('is-prompt-visible');
            }
            for (const tabbed of row.querySelectorAll('[data-tabbed-artifact]')) {
              switchArtifactTab(tabbed, tabbed.dataset.defaultTab || 'terminal');
              tabbed.classList.remove('is-running', 'is-done');
            }
            showInitialCommandPrompts(row);
          };

          const revealTyping = async (target, isCurrent) => {
            if (target.dataset.runCommand === 'true') {
              target.classList.add('is-prompt-visible');
            }
            if (target.hasAttribute('data-reveal-line')) {
              target.classList.add('is-visible');
              await sleep(Number(target.dataset.revealPause || 0));
              if (!isCurrent()) return false;
            }
            const delayBySpeed = {
              command: 50,
              medium: 25,
              fast: 14,
              'generated-file': 5,
              'schema-add': 58,
            };
            const delay = delayBySpeed[target.dataset.typeSpeed] || 14;
            for (const character of prepareTyping(target)) {
              if (!isCurrent()) return false;
              if (character.classList.contains('is-visible')) continue;
              character.classList.add('is-visible');
              await sleep(delay);
            }
            return true;
          };

          const switchArtifactTab = (tabbed, activeTab) => {
            for (const tab of tabbed.querySelectorAll('[data-tab-for]')) {
              tab.classList.toggle('is-active', tab.dataset.tabFor === activeTab);
              tab.setAttribute('aria-selected', String(tab.dataset.tabFor === activeTab));
            }
            for (const panel of tabbed.querySelectorAll('[data-tab-panel]')) {
              panel.classList.toggle('is-active', panel.dataset.tabPanel === activeTab);
            }
          };

          const terminalOutputsForCommand = (target, terminal) => {
            const code = target.closest('code');
            if (!code) return Array.from(terminal?.querySelectorAll('[data-terminal-output]') || []);

            const outputs = [];
            let afterTarget = false;
            for (const child of code.children) {
              if (child === target) {
                afterTarget = true;
                continue;
              }
              if (!afterTarget) continue;
              if (child.matches('[data-type-speed][data-run-command="true"]')) break;
              if (child.matches('[data-terminal-output]')) outputs.push(child);
            }

            return outputs;
          };

          const setReplayState = (row, state) => {
            row.dataset.walkthroughState = state;
            for (const button of row.querySelectorAll('[data-replay-demo]')) {
              button.dataset.replayState = state;
            }
          };

          const playRow = async row => {
            const runId = String(Number(row.dataset.walkthroughRun || '0') + 1);
            row.dataset.walkthroughRun = runId;
            const isCurrent = () => row.dataset.walkthroughRun === runId;
            resetRow(row);
            setReplayState(row, 'running');

            try {
              for (const target of typingTargetsForRow(row)) {
                const completed = await revealTyping(target, isCurrent);
                if (!completed || !isCurrent()) return;

                if (target.dataset.runCommand === 'true') {
                  const terminal = target.closest('.artifact');
                  if (terminal) terminal.classList.add('is-running');
                  await sleep(650);
                  let previousOutput = null;
                  for (const output of terminalOutputsForCommand(target, terminal)) {
                    if (!isCurrent()) return;
                    if (previousOutput) {
                      if (previousOutput.hasAttribute('data-dismiss-before-next')) {
                        previousOutput.classList.add('is-dismissed');
                      }
                      for (const promptPart of previousOutput.querySelectorAll('[data-dismiss-before-next], [data-corner-before-next]')) {
                        promptPart.classList.add('is-dismissed');
                      }
                      for (const promptPart of previousOutput.querySelectorAll('[data-corner-after-next]')) {
                        promptPart.classList.add('is-visible');
                      }
                    }
                    output.classList.add('is-visible');
                    previousOutput = output;
                    await sleep(Number(output.dataset.outputPause || 260));
                  }
                  if (terminal) {
                    terminal.classList.remove('is-running');
                    terminal.classList.add('is-done');
                  }
                  await sleep(170);

                  const replacement = terminal
                    ?.closest('.artifact-swap')
                    ?.querySelector('[data-replacement-artifact]');
                  const tabbedReplacement = terminal
                    ?.closest('[data-tabbed-artifact]')
                    ?.querySelector('[data-replacement-artifact]');
                  const tabbed = terminal?.closest('[data-tabbed-artifact]');
                  if (replacement) {
                    terminal.classList.add('is-replaced');
                    replacement.classList.add('is-visible');
                  }
                  if (tabbed && tabbedReplacement) {
                    switchArtifactTab(tabbed, 'src');
                    tabbedReplacement.classList.add('is-visible');
                  }
                }
              }

              for (const pop of row.querySelectorAll('[data-pop-after-typing]')) {
                if (!isCurrent()) return;
                pop.classList.add('is-visible');
                await sleep(Number(pop.dataset.popPause || 120));
              }

              for (const artifact of row.querySelectorAll('[data-generated-artifact]')) {
                if (!isCurrent()) return;
                artifact.classList.add('is-visible');
                await sleep(110);
              }
            } finally {
              if (isCurrent()) setReplayState(row, 'done');
            }
          };

          for (const row of rows) {
            for (const target of row.querySelectorAll('[data-type-speed]')) {
              prepareTyping(target);
            }
          }
          document.documentElement.classList.add('landing-anim-ready');
          for (const row of rows) {
            resetRow(row);
            setReplayState(row, 'idle');
            row.addEventListener('landing-demo-replay', () => void playRow(row));
            for (const replayButton of row.querySelectorAll('[data-replay-demo]')) {
              replayButton.addEventListener('click', () => void playRow(row));
            }
            for (const tabbed of row.querySelectorAll('[data-tabbed-artifact]')) {
              for (const tab of tabbed.querySelectorAll('[data-tab-for]')) {
                tab.addEventListener('click', () => {
                  switchArtifactTab(tabbed, tab.dataset.tabFor || 'terminal');
                });
              }
            }
          }

          if (!('IntersectionObserver' in window)) {
            for (const row of rows) void playRow(row);
            return;
          }

          const observer = new IntersectionObserver(
            entries => {
              for (const entry of entries) {
                const row = entry.target.closest('[data-walkthrough-step]');
                if (!row) continue;
                const fullyVisible = entry.isIntersecting && entry.intersectionRatio >= 0.98;
                if (!fullyVisible) {
                  row.dataset.walkthroughFullyVisible = 'false';
                  continue;
                }
                if (row.dataset.walkthroughFullyVisible === 'true') continue;
                row.dataset.walkthroughFullyVisible = 'true';
                void playRow(row);
              }
            },
            { rootMargin: '0px', threshold: [0, 0.98, 1] },
          );

          for (const row of rows) {
            observer.observe(row.querySelector('.feature-demo') || row);
          }
        })();
      </script>

      <script is:inline>
        (() => {
          for (const showcase of document.querySelectorAll('[data-feature-showcase]')) {
            const switchFeature = feature => {
              for (const option of showcase.querySelectorAll('[data-feature-for]')) {
                const active = option.dataset.featureFor === feature;
                option.classList.toggle('is-active', active);
                option.setAttribute('aria-selected', String(active));
              }
              for (const panel of showcase.querySelectorAll('[data-feature-panel]')) {
                panel.classList.toggle('is-active', panel.dataset.featurePanel === feature);
              }
            };

            for (const option of showcase.querySelectorAll('[data-feature-for]')) {
              option.addEventListener('click', () => {
                switchFeature(option.dataset.featureFor || 'admin');
                showcase.closest('[data-walkthrough-step]')?.dispatchEvent(new CustomEvent('landing-demo-replay'));
              });
            }
          }
        })();
      </script>

      {/*
        Video animation variants are enabled with `?animation=<name>`:

          - `?animation=sequential`: a single large stage that plays the three
            beats (schema, generate, draft) in sequence, replacing the
            feature walkthrough. This is the main animated treatment.
          - `?animation=a|b|c|d`: the original three-panel alternatives,
            each supported feature keeps its copy but its body gets swapped for the
            matching `alt-<letter>-<key>` video.

        When no `animation` param is set, the page keeps the feature
        walkthrough above and progressively enhances it with lightweight DOM
        typing/reveal animation.
      */}
      <script is:inline>
        (() => {
          const params = new URLSearchParams(window.location.search);
          const raw = params.get('animation');
          if (!raw) return;
          const name = raw.trim().toLowerCase();
          const grid = document.getElementById('value-panels');
          if (!grid) return;

          if (name === 'sequential') {
            // Single large stage. Replace the three-card grid wholesale.
            const stage = document.createElement('section');
            stage.className = 'animation-stage';
            stage.innerHTML = `
              <video
                class="animation-stage-video"
                autoplay
                loop
                muted
                playsinline
                preload="metadata"
                poster="/assets/animations/anim-sequential.poster.jpg"
              >
                <source src="/assets/animations/anim-sequential.webm" type="video/webm" />
                <source src="/assets/animations/anim-sequential.mp4" type="video/mp4" />
              </video>
              <img
                class="animation-stage-fallback"
                src="/assets/animations/anim-sequential.poster.jpg"
                alt="sqlfu: edit schema, generate types, draft migrations."
                loading="lazy"
              />
            `;
            grid.replaceWith(stage);
            return;
          }

          if (['a', 'b', 'c', 'd'].includes(name)) {
            const animatedKeys = new Set(['schema', 'generate', 'draft']);
            // Alternative three-panel treatments: inject a `<video>` inside
            // each feature that already has a matching animation asset.
            for (const panel of grid.querySelectorAll('.value-panel')) {
              const key = panel.dataset.animationKey;
              if (!key || !animatedKeys.has(key)) continue;
              const slug = `alt-${name}-${key}`;
              const media = document.createElement('div');
              media.className = 'value-media';
              media.innerHTML = `
                <video
                  class="value-video"
                  autoplay
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  poster="/assets/animations/${slug}.poster.jpg"
                >
                  <source src="/assets/animations/${slug}.webm" type="video/webm" />
                  <source src="/assets/animations/${slug}.mp4" type="video/mp4" />
                </video>
                <img
                  class="value-video-fallback"
                  src="/assets/animations/${slug}.poster.jpg"
                  alt=""
                  loading="lazy"
                />
              `;
              const heading = panel.querySelector('.eyebrow');
              if (heading) heading.after(media);
              else panel.prepend(media);
            }
          }
        })();
      </script>

    </div>

    {/* Landing-page theme toggle. Uses the same 'starlight-theme' localStorage key
        Starlight owns, so docs and landing stay in sync. Cycles light → dark → auto. */}
    <script is:inline>
      (() => {
        const key = 'starlight-theme';
        const button = document.getElementById('landing-theme-toggle');
        if (!button) return;

        const prefersLight = () => window.matchMedia('(prefers-color-scheme: light)').matches;

        const applyTheme = mode => {
          const resolved = mode === 'auto' ? (prefersLight() ? 'light' : 'dark') : mode;
          document.documentElement.dataset.theme = resolved;
          button.dataset.themeMode = mode;
        };

        const readMode = () => {
          const stored = localStorage.getItem(key);
          return stored === 'light' || stored === 'dark' ? stored : 'auto';
        };

        const writeMode = mode => {
          if (mode === 'auto') localStorage.setItem(key, '');
          else localStorage.setItem(key, mode);
        };

        applyTheme(readMode());

        button.addEventListener('click', () => {
          const current = readMode();
          const next = current === 'light' ? 'dark' : current === 'dark' ? 'auto' : 'light';
          writeMode(next);
          applyTheme(next);
        });

        // Keep landing in sync if the OS flips while we're on 'auto'.
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
          if (readMode() === 'auto') applyTheme('auto');
        });
      })();
    </script>
  </body>
</html>
