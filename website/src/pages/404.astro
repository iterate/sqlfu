---
const title = 'Page not found - sqlfu';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style>
      :root {
        --bg: #f6efe2;
        --bg-start: #efe1c6;
        --bg-end: #fffdf9;
        --text: #201710;
        --muted: #6f5947;
        --line: rgba(85, 52, 24, 0.16);
        --accent: #9d4d12;
        --accent-strong: #6f2d00;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1a1410;
          --bg-start: #15100c;
          --bg-end: #1f1812;
          --text: #f0e6d6;
          --muted: #b5a58f;
          --line: rgba(240, 230, 214, 0.14);
          --accent: #e89b66;
          --accent-strong: #f2b07f;
          color-scheme: dark;
        }
      }

      * {
        box-sizing: border-box;
      }

      html {
        min-height: 100%;
        background:
          radial-gradient(circle at top, rgba(232, 155, 102, 0.12), transparent 32rem),
          linear-gradient(180deg, var(--bg-start) 0%, var(--bg) 32%, var(--bg-end) 100%);
      }

      body {
        min-height: 100dvh;
        margin: 0;
        color: var(--text);
        font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
      }

      .shell {
        min-height: 100dvh;
        max-width: 76rem;
        margin: 0 auto;
        padding: 1.25rem 1.1rem 4rem;
        display: grid;
        grid-template-rows: auto 1fr;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 0 2rem;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--accent);
        font-family: ui-monospace, 'SFMono-Regular', monospace;
        font-size: 0.84rem;
        letter-spacing: 0.14em;
        line-height: 1;
        text-decoration: none;
        text-transform: uppercase;
      }

      .brand img {
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 0.3rem;
        object-fit: contain;
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.95rem;
      }

      a {
        color: var(--accent-strong);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.15em;
      }

      .nav a {
        color: var(--muted);
        text-decoration: none;
      }

      .nav a:hover {
        color: var(--accent);
      }

      main {
        display: grid;
        align-content: center;
        max-width: 46rem;
        padding: 6rem 0;
      }

      .code {
        margin: 0 0 1rem;
        color: var(--accent);
        font-family: ui-monospace, 'SFMono-Regular', monospace;
        font-size: 0.9rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      h1 {
        max-width: 11ch;
        margin: 0;
        font-size: 7.5rem;
        line-height: 0.9;
        letter-spacing: 0;
      }

      p {
        max-width: 36rem;
        margin: 1.5rem 0 0;
        color: var(--muted);
        font-size: 1.35rem;
        line-height: 1.45;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 2rem;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.7rem 1rem;
        border: 1px solid var(--line);
        border-radius: 0.5rem;
        color: var(--text);
        text-decoration: none;
      }

      .button.primary {
        border-color: var(--accent);
        background: var(--accent);
        color: var(--bg-end);
      }

      @media (max-width: 44rem) {
        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        main {
          padding: 4rem 0;
        }

        h1 {
          font-size: 4.5rem;
        }

        p {
          font-size: 1.15rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">
          <img src="/logo.png" alt="" width="28" height="28" />
          <span>sqlfu</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="/docs/getting-started">Docs</a>
          <a href="/blog">Blog</a>
          <a href="/ui?demo=1">Demo</a>
        </nav>
      </header>
      <main>
        <p class="code">404</p>
        <h1>page not found.</h1>
        <p>This URL does not map to a sqlfu page. Try the docs, the browser demo, or head back home.</p>
        <div class="actions">
          <a class="button primary" href="/docs/getting-started">Open docs</a>
          <a class="button" href="/">Go home</a>
        </div>
      </main>
    </div>
  </body>
</html>
