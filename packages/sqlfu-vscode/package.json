{
  "name": "@sqlfu/vscode",
  "displayName": "sqlfu",
  "version": "0.0.1-0",
  "private": true,
  "description": "VS Code extension for sqlfu projects. Today: one command — open the sqlfu UI for the current workspace.",
  "categories": [
    "Other"
  ],
  "publisher": "sqlfu",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "vscode:prepublish": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "sqlfu.openUi",
        "title": "sqlfu: Open UI",
        "category": "sqlfu"
      }
    ]
  },
  "activationEvents": [
    "onCommand:sqlfu.openUi"
  ],
  "engines": {
    "vscode": "^1.90.0"
  }
}
